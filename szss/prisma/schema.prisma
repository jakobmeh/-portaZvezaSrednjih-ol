generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  PARTICIPANT
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TournamentRegistrationStatus {
  CONFIRMED
  WAITLISTED
}

enum TournamentFormat {
  GROUP_STAGE
  KNOCKOUT
  COMBINED
}

enum MatchStatus {
  UPCOMING
  LIVE
  FINISHED
  CANCELLED
}

model User {
  id               String         @id @default(cuid())
  fullName         String
  email            String         @unique
  passwordHash     String
  schoolName       String
  role             UserRole
  approvalStatus   ApprovalStatus @default(PENDING)
  schoolCardImage  String?
  isPro            Boolean        @default(false)
  proUntil         DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  organizedEvents  Tournament[]   @relation("TournamentOrganizer")
  teams            Team[]
  teamMemberships  TeamMember[]
  sessions         Session[]
  registrations    TournamentRegistration[]
  notifications    Notification[]
  sentMessages     Message[]      @relation("MessageSender")
  followedTournaments TournamentFollower[]
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Tournament {
  id                      String                   @id @default(cuid())
  title                   String
  slug                    String                   @unique
  sport                   String
  description             String
  location                String
  date                    DateTime
  maxTeams                Int
  format                  TournamentFormat         @default(GROUP_STAGE)
  selfRegistrationEnabled Boolean                  @default(false)
  selfRegistrationToken   String?                  @unique
  organizerId             String
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  organizer               User                     @relation("TournamentOrganizer", fields: [organizerId], references: [id], onDelete: Cascade)
  registrations           TournamentRegistration[]
  announcements           Announcement[]
  messages                Message[]
  matches                 Match[]
  followers               TournamentFollower[]
}

model Team {
  id             String                   @id @default(cuid())
  name           String
  sport          String
  schoolName     String
  createdById    String
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  createdBy      User                     @relation(fields: [createdById], references: [id], onDelete: Cascade)
  players        TeamMember[]
  registrations  TournamentRegistration[]
  homeMatches    Match[]                  @relation("HomeTeam")
  awayMatches    Match[]                  @relation("AwayTeam")
}

model TeamMember {
  id         String   @id @default(cuid())
  teamId     String
  userId     String?
  fullName   String
  className  String?
  position   String?
  createdAt  DateTime @default(now())
  team       Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user       User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TournamentRegistration {
  id            String                       @id @default(cuid())
  tournamentId  String
  teamId        String
  userId        String
  status        TournamentRegistrationStatus @default(CONFIRMED)
  createdAt     DateTime                     @default(now())
  tournament    Tournament                   @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  team          Team                         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user          User                         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, teamId])
}

model Match {
  id           String      @id @default(cuid())
  tournamentId String
  homeTeamId   String
  awayTeamId   String
  scoreHome    Int?
  scoreAway    Int?
  scheduledAt  DateTime?
  location     String?
  court        String?
  status       MatchStatus @default(UPCOMING)
  round        Int?
  group        String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  tournament   Tournament  @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  homeTeam     Team        @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam     Team        @relation("AwayTeam", fields: [awayTeamId], references: [id])
}

model TournamentFollower {
  id           String   @id @default(cuid())
  userId       String
  tournamentId String
  teamId       String?
  createdAt    DateTime @default(now())
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@unique([userId, tournamentId])
}

model Announcement {
  id           String      @id @default(cuid())
  tournamentId String?
  title        String
  content      String
  createdAt    DateTime    @default(now())
  tournament   Tournament? @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
}

model Notification {
  id         String   @id @default(cuid())
  userId     String
  title      String
  content    String
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Message {
  id           String     @id @default(cuid())
  tournamentId String
  senderId     String
  senderName   String
  content      String
  createdAt    DateTime   @default(now())
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  sender       User       @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
}
